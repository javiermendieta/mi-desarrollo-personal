generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  events          CalendarEvent[]
  sports          Sport[]
  yogaExercises   YogaExercise[]
  meditationSessions MeditationSession[]
  yogaSessions    YogaSession[]
  books           Book[]
  diaryEntries    DiaryEntry[]
  limitingBeliefs LimitingBelief[]
  goals           Goal[]
  habits          Habit[]
  transactions    Transaction[]
  savingsGoals    SavingsGoal[]
  budgets         Budget[]
  accountPlan     AccountPlanItem[]
  pnlData         PNLData[]
  sleepLogs       SleepLog[]
  hydrationLogs   HydrationLog[]
  healthEntries   HealthEntry[]
  medicalAppointments MedicalAppointment[]
  medicalTasks    MedicalTask[]
  quickNotes      QuickNote[]
  conversations   Conversation[]
  projects        Project[]
  commercialLeads CommercialLead[]
  socialMediaPosts SocialMediaPost[]
  projectAlerts   ProjectAlert[]
  activities      Activity[]
  settings        Settings?
  aiProfile       AIProfile?
}

model Activity {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String
  action      String
  referenceId String?
  title       String
  details     Json?
  date        DateTime @default(now())
  
  @@index([userId, date])
  @@index([userId, type])
}

model Settings {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  theme       String   @default("system")
  language    String   @default("es")
  notifications Boolean @default(true)
  weekStartsOn Int     @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AIProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id])
  personality       String?  @db.Text
  lifeGoals         String?  @db.Text
  currentChallenges String?  @db.Text
  values            String?  @db.Text
  interests         String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model CalendarEvent {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  title           String
  description     String?   @db.Text
  startDate       DateTime
  endDate         DateTime?
  color           String    @default("#3b82f6")
  category        String    @default("Personal")
  isRecurring     Boolean   @default(false)
  recurrencePattern String?
  recurrenceEnd   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId, startDate])
}

model Sport {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  icon      String   @default("dumbbell")
  color     String   @default("#22c55e")
  isActive  Boolean  @default(true)
  routines  Json?
  sessions  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model YogaExercise {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String
  description String?  @db.Text
  duration    Int      @default(10)
  difficulty  String   @default("beginner")
  category    String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MeditationSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime
  duration  Int
  type      String   @default("mindfulness")
  notes     String?  @db.Text
  completed Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([userId, date])
}

model YogaSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime
  duration  Int      @default(0)
  completed Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, date])
}

model Book {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  title        String
  author       String?
  totalPages   Int
  currentPage  Int      @default(0)
  startDate    DateTime  @default(now())
  finishDate   DateTime?
  status       String   @default("reading")
  notes        Json?
  pdfUrl       String?
  pdfName      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model DiaryEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime
  title     String?
  content   String   @db.Text
  mood      String   @default("good")
  tags      Json?
  gratitude Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
}

model LimitingBelief {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  belief       String
  explanation  String?  @db.Text
  dailyWork    String?  @db.Text
  progress     Int      @default(0)
  isOvercome   Boolean  @default(false)
  reflections  Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Goal {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  title        String
  description  String?  @db.Text
  timeframe    String   @default("short")
  category     String   @default("personal")
  deadline     DateTime?
  progress     Int      @default(0)
  isCompleted  Boolean  @default(false)
  milestones   Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Habit {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String
  description String?  @db.Text
  icon        String   @default("check")
  color       String   @default("#22c55e")
  frequency   String   @default("daily")
  customDays  Json?
  isActive    Boolean  @default(true)
  logs        Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String
  amount      Float
  category    String   @default("other")
  description String?
  date        DateTime
  accountId   String?
  createdAt   DateTime @default(now())

  @@index([userId, date])
}

model SavingsGoal {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  name          String
  targetAmount  Float
  currentAmount Float    @default(0)
  deadline      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Budget {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  category    String
  limitAmount Float
  month       String
  createdAt   DateTime @default(now())

  @@index([userId, month])
}

// Plan de Cuentas para Finanzas
model AccountPlanItem {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  code        String
  name        String
  type        String   // income, expense
  category    String   // ventas, costos, gastos, etc.
  subcategory String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, type])
  @@index([userId, category])
}

// Estado de Pérdidas y Ganancias
model PNLData {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  period        String   // formato: YYYY-MM
  accountPlans  Json?    // [{ accountId, theoretical }]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, period])
}

model SleepLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime
  sleepTime String?
  wakeTime  String?
  quality   Int      @default(3)
  notes     String?
  createdAt DateTime @default(now())

  @@index([userId, date])
}

model HydrationLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime
  glasses   Int      @default(0)
  target    Int      @default(8)
  createdAt DateTime @default(now())

  @@index([userId, date])
}

model HealthEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime
  weight    Float?
  steps     Int?
  calories  Int?
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  @@index([userId, date])
}

model MedicalAppointment {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  doctor      String
  specialty   String?
  date        DateTime
  location    String?
  notes       String?   @db.Text
  status      String    @default("scheduled")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, date])
}

model MedicalTask {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  title       String
  description String?   @db.Text
  dueDate     DateTime?
  completed   Boolean   @default(false)
  priority    String    @default("medium")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, dueDate])
}

model QuickNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  content   String?  @db.Text
  category  String   @default("Otros")
  color     String   @default("#ffffff")
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String   @default("Nueva conversación")
  messages  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Proyectos
model Project {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String
  description String?  @db.Text
  client      String?
  status      String   @default("active") // active, completed, on-hold
  type        String   @default("client") // client, internal
  startDate   DateTime?
  endDate     DateTime?
  color       String   @default("#3b82f6")
  tasks       Json?
  milestones  Json?
  documents   Json?
  meetings    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, status])
}

// Leads comerciales
model CommercialLead {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  name        String
  company     String?
  email       String?
  phone       String?
  source      String?
  status      String    @default("new") // new, contacted, proposal, negotiation, won, lost
  value       Float?
  probability Int?
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, status])
}

// Posts de redes sociales
model SocialMediaPost {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  platform    String    // instagram, twitter, linkedin, etc.
  content     String    @db.Text
  status      String    @default("draft") // draft, scheduled, published
  scheduledAt DateTime?
  publishedAt DateTime?
  mediaUrl    String?
  tags        Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, platform])
  @@index([userId, scheduledAt])
}

// Alertas de proyectos
model ProjectAlert {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  projectId   String?
  type        String    // deadline, task, meeting, etc.
  title       String
  message     String?
  severity    String    @default("info") // info, warning, error
  isRead      Boolean   @default(false)
  isDismissed Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}
